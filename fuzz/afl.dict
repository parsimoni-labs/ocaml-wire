# Common Wire AFL control bytes and boundary payloads.
mode_decode="\x00"
mode_validate="\x02"
mode_agree="\x03"
zero="\x00"
one="\x01"
u8_max="\xff"
i8_min="\x80"
u16be_one="\x00\x01"
u16be_max="\xff\xff"
u32be_max="\xff\xff\xff\xff"
all_zeros_bad="\x00\x01\x00"
negative_len="\xff"
enum_unknown="\xee"
short="\x05"
long_len="\xff\xff"
