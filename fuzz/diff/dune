; Differential AFL fuzzer: OCaml wire codec vs EverParse C validator, driven by
; the registry. The EverParse C validators and FFI stubs are generated, so the
; fuzzer only builds when EverParse is available (BUILD_EVERPARSE=1, 3d.exe in
; PATH). The generator (gen/) is pure OCaml and always builds.

(rule
 (enabled_if
  (= %{env:BUILD_EVERPARSE=} "1"))
 ; [gen_diff.exe] also archives the per-codec validators into [libdiffcodecs.a]
 ; (via [Wire_stubs.build_codec_archive]) so [wire_ffi.c] -- which includes only
 ; the headers -- links against them as separate translation units. Compiling
 ; each codec as its own translation unit keeps the per-codec shared types (an
 ; [enum], a synthesised [_RefByte_*] / [Se_*] element struct) confined to it, so
 ; any set of codecs links without colliding on a duplicate definition.
 (targets
  (dir schemas)
  wire_ffi.c
  stubs.ml
  diff_index.ml
  libdiffcodecs.a)
 (deps gen/gen_diff.exe)
 (action
  (run %{dep:gen/gen_diff.exe} schemas)))

(executable
 (name fuzz)
 (modules fuzz stubs diff_index)
 (enabled_if
  (= %{env:BUILD_EVERPARSE=} "1"))
 (libraries wire fuzz_gen diff_codecs alcobar)
 (foreign_archives diffcodecs)
 (foreign_stubs
  (language c)
  (names wire_ffi)
  ; A raw -I (not include_dirs) because [schemas] is generated by the rule above,
  ; and include_dirs requires the directory to already exist. The trade-off is
  ; that dune does not track the #included schema headers as a dependency, so an
  ; incremental rebuild after a schema change can be stale; a clean build (as in
  ; CI) is always correct.
  (flags :standard -I schemas)))

(rule
 (alias runtest)
 (enabled_if
  (and
   (= %{env:BUILD_EVERPARSE=} "1")
   (<> %{profile} afl)))
 (deps fuzz.exe ../afl.dict)
 (action
  (run %{exe:fuzz.exe})))

; afl-fuzz searches PATH for a target with no '/', so pass [./fuzz.exe] (the
; cwd is this dir in the build tree, where fuzz.exe is built).

(rule
 (alias fuzz)
 (enabled_if
  (and
   (= %{env:BUILD_EVERPARSE=} "1")
   (= %{profile} afl)))
 (deps fuzz.exe ../afl.dict)
 (action
  (progn
   (run %{exe:fuzz.exe} --gen-corpus corpus)
   (run
    afl-fuzz
    -V
    60
    -t
    8000
    -x
    ../afl.dict
    -i
    corpus
    -o
    _fuzz
    --
    ./fuzz.exe
    @@))))
